APP_NAME=Adult Commerce Platform API
APP_ENV=development
DATABASE_URL=sqlite:///./adult_platform.db
CORS_ORIGINS=http://localhost:5173

JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
LOGIN_CHALLENGE_EXPIRE_MINUTES=10
IP_RATE_LIMIT_WINDOW_MINUTES=5
IP_RATE_LIMIT_MAX_REQUESTS=20
IP_RATE_LIMIT_BLOCK_MINUTES=10

ADMIN_2FA_ENABLED=true
ADMIN_2FA_ISSUER=adultapp
ADMIN_IP_ALLOWLIST=127.0.0.1,10.0.0.0/8
DUAL_APPROVAL_ENABLED=true
AUDIT_LOG_HASH_CHAIN=true

UPLOADS_DIR=./uploads
MEDIA_BASE_URL=http://localhost:8000/media
