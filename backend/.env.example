APP_NAME=Adult Commerce Platform API
APP_ENV=development
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/adultapp
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://adultapp.pages.dev
CORS_ORIGIN_REGEX=https://.*\.adultapp\.pages\.dev

JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
LOGIN_CHALLENGE_EXPIRE_MINUTES=10
IP_RATE_LIMIT_WINDOW_MINUTES=5
IP_RATE_LIMIT_MAX_REQUESTS=20
IP_RATE_LIMIT_BLOCK_MINUTES=10

PG_PRIMARY_PROVIDER=kginicis
PG_PRIMARY_MERCHANT_ID=change-me
PG_PRIMARY_API_KEY=change-me
PG_PRIMARY_WEBHOOK_SECRET=change-me
PG_SECONDARY_PROVIDER=danalpay
PG_SECONDARY_MERCHANT_ID=change-me
PG_SECONDARY_API_KEY=change-me
PG_SECONDARY_WEBHOOK_SECRET=change-me
PG_PORTONE_STORE_ID=change-me-pg-store-id
PG_PORTONE_CHANNEL_KEY=change-me-pg-channel-key
PORTONE_API_BASE_URL=https://api.portone.io
PORTONE_API_SECRET=change-me-portone-api-secret

# PG TEST / LIVE SPLIT
# 테스트값은 지금 먼저 입력
PG_PORTONE_STORE_ID_TEST=change-me-pg-store-id-test
PG_PORTONE_CHANNEL_KEY_TEST=change-me-pg-channel-key-test
PG_PRIMARY_MERCHANT_ID_TEST=change-me-merchant-test
PORTONE_WEBHOOK_SECRET_TEST=change-me-portone-webhook-test


# Toss test channel helper values (keep test/live fully separated)
TOSS_MID_TEST=iamporttest_3
TOSS_CLIENT_KEY_TEST=change-me-toss-client-key-test
TOSS_SECRET_KEY_TEST=change-me-toss-secret-key-test

# 운영값은 마지막 단계에서만 입력
TOSS_MID_LIVE=change-me-toss-mid-live
TOSS_CLIENT_KEY_LIVE=change-me-toss-client-key-live
TOSS_SECRET_KEY_LIVE=change-me-toss-secret-key-live
# 운영값은 마지막 단계에서만 입력
PG_PORTONE_STORE_ID_LIVE=change-me-pg-store-id-live
PG_PORTONE_CHANNEL_KEY_LIVE=change-me-pg-channel-key-live
PG_PRIMARY_MERCHANT_ID_LIVE=change-me-merchant-live
PORTONE_WEBHOOK_SECRET_LIVE=change-me-portone-webhook-live
# 운영 MID / merchant 실제값은 운영 직전 단계에서만 입력

PG_WEBHOOK_PATH=/api/payments/webhooks/pg
PG_REFUND_WEBHOOK_PATH=/api/payments/webhooks/refund
PG_SETTLEMENT_BASIS_NOTE="초기에는 관리자 승인형 판매자/상품 공개 구조로 운영하며, 관리자 직접판매와 사업자 판매물품 중개를 병행"

ADULT_VERIFICATION_PROVIDER=portone_pass
ADULT_VERIFICATION_PROVIDER_LABEL=PortOne 기반 PASS/휴대폰 본인확인
ADULT_VERIFICATION_CLIENT_ID=change-me
ADULT_VERIFICATION_CLIENT_SECRET=change-me
ADULT_VERIFICATION_WEBHOOK_SECRET=change-me-webhook
ADULT_VERIFICATION_CALLBACK_WEB=https://api.example.com/auth/adult/callback
ADULT_VERIFICATION_CALLBACK_APP=adultapp://auth/adult/callback
ADULT_VERIFICATION_CALLBACK_IDENTITY_WEB=https://api.example.com/auth/identity/callback
ADULT_VERIFICATION_CALLBACK_IDENTITY_APP=adultapp://auth/identity/callback
ADULT_VERIFICATION_TEST_MODE=true
ADULT_VERIFICATION_PROD_ENABLED=false
ADULT_VERIFICATION_ALLOWED_PROVIDERS=PASS,휴대폰
ADULT_VERIFICATION_PORTONE_STORE_ID=change-me-portone-store-id
ADULT_VERIFICATION_PORTONE_CHANNEL_KEY=change-me-portone-channel-key
ADULT_VERIFICATION_WEBHOOK_PATH=/api/auth/verification/webhook
ADULT_VERIFICATION_ERROR_CODE_MAP=INVALID_IDENTITY:본인확인 실패,MINOR_BLOCKED:미성년 차단,SIGNATURE_ERROR:콜백 서명 오류,PROVIDER_TIMEOUT:공급사 응답 지연

ADMIN_2FA_ENABLED=true
ADMIN_2FA_ISSUER=adultapp
ADMIN_IP_ALLOWLIST=127.0.0.1,10.0.0.0/8
DUAL_APPROVAL_ENABLED=true
AUDIT_LOG_HASH_CHAIN=true

UPLOADS_DIR=./uploads
MEDIA_BASE_URL=https://adultapp-production.up.railway.app/media

RECONSENT_GRACE_DAYS=7
RECONSENT_ENFORCEMENT_MODE=limited_access
RECONSENT_REDIRECT_PATH=/reconsent

ADULT_VERIFICATION_ROLLOUT_STRATEGY="1차는 PortOne 기반 PASS 통합 연동으로 시작하고, 운영 안정화 후 NICE 또는 Danal 직접 전환 여부를 검토"
ADULT_VERIFICATION_PROD_CUTOVER_CHECKLIST="본인확인 실연동,콜백 검증,서버 저장,장애 알림,운영 점검표 완료 후 운영키 전환"
MINOR_BLOCK_RETENTION_DAYS=365
MINOR_BLOCK_RETENTION_SCOPE="최소 식별값과 차단 이력만 분쟁 대응 범위에서 1년 보관 후 파기"
ADMIN_EXCEPTION_APPROVAL_MODE="초기에는 내부 승인 문서 + 감사로그 방식, 이후 백오피스 승인 화면으로 전환"
ADMIN_EXCEPTION_AUDIT_REQUIRED=true

OPS_ALERT_SLACK_ENABLED=true
OPS_ALERT_SLACK_WEBHOOK_URL=change-me-slack
OPS_ALERT_EMAIL_ENABLED=true
OPS_ALERT_EMAIL_TO=ops@example.com
OPS_CHECKLIST_DOCUMENT_PATH=./docs/ops_preflight_checklist.md
LOCATION_FEATURE_MODE=region_band_only
LOCATION_REALTIME_SHARING_ENABLED=false
LOCATION_DISTANCE_BAND_LABELS=0-3km,3-10km,10-30km,30km+
BETA_BUSINESS_INFO_DB_OVERRIDE_ENABLED=true
MINOR_BLOCK_PURGE_CRON=0 4 * * *
MINOR_BLOCK_PURGE_BATCH_ENABLED=true
MINOR_BLOCK_PURGE_RUNBOOK_PATH=./docs/ops_minor_block_purge.md
PORTONE_SDK_ENABLED=true
PAYMENTS_ENV_SPLIT_ENABLED=true

STARTUP_DB_INIT_ENABLED=false
STARTUP_SEED_ENABLED=false
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_STATEMENT_TIMEOUT_MS=10000
