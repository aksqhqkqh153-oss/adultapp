{
  "name": "adult-commerce-platform-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/lib/tsc.js -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js -b --pretty false",
    "cf:login": "npx --yes wrangler@4 login",
    "cf:whoami": "npx --yes wrangler@4 whoami",
    "cf:build": "node ./node_modules/typescript/lib/tsc.js -b && node ./node_modules/vite/bin/vite.js build",
    "cf:deploy": "npx --yes wrangler@4 pages deploy dist --project-name adultapp --branch main --commit-dirty=true",
    "cf:deploy:project": "npx --yes wrangler@4 pages deploy dist --commit-dirty=true"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
